# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Engine settings ───────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-8            # analysis quality matters; cost negligible at batch size
CRITIC_ROUNDS=1                         # generator→critic→revise passes per account

# ── Notion output (optional) ──────────────────────────────────────────────────
# Leave blank to skip publishing — the engine still prints and writes seen_accounts.json.
# NOTION_DATABASE_ID: open your DB in the browser → copy the ID from the URL.
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Churn-detection thresholds (the ARR Illusion knobs) ───────────────────────
CONSUMPTION_RATIO_THRESHOLD=0.85        # run-rate / booked-ARR below this = under-consuming
DECAY_VELOCITY_THRESHOLD=-0.02          # avg MoM token change at/below this = token decay (-2%)
RENEWAL_WARNING_DAYS=90                 # flag accounts renewing within this window

# ── Data source ───────────────────────────────────────────────────────────────
CSV_DATA_PATH=accounts.csv
ACCOUNT_NAME=                           # leave blank to run for all accounts

# ── KvK Handelsregister (optional) ────────────────────────────────────────────
# Dutch business registry identity check. Without a key the engine uses a deterministic
# synthetic status so the pipeline runs offline. Get a key: https://developers.kvk.nl
KVK_API_KEY=

# ── X (Twitter) scheduler (optional) ──────────────────────────────────────────
# developer.x.com → create app → OAuth 1.0a Read+Write → generate access token.
# Without keys, `python x_scheduler.py post` prints copy-paste text instead.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── X automation extras (optional) ────────────────────────────────────────────
# Blog teasers use Claude if set; trend watcher prefers Grok, falls back to HN.
XAI_API_KEY=

# ── X API credit alerts (optional) ───────────────────────────────────────────
# Set to your console.x.com balance after each top-up. Opens a GitHub Issue when low.
X_CREDIT_BALANCE_USD=
X_CREDIT_WARN_USD=5
X_CREDIT_CRITICAL_USD=2
BLOG_PROMO_TZ=Europe/Amsterdam
BLOG_PROMO_HOUR=9
TREND_MAX_PER_WEEK=4
